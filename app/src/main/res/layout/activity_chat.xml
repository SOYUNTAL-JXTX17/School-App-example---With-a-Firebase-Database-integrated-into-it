<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".mensajesApartado.ChatActivity">

    <LinearLayout
        android:id="@+id/layoutMensajes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:orientation="horizontal">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:background="@drawable/inicio_bienvenida_background"
                android:layout_marginBottom="20dp"
                android:paddingHorizontal="32dp"
                android:paddingBottom="20dp">

                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="bottom">

                    <ImageView
                        android:id="@+id/backButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/arrow_back"
                        android:tint="?attr/textos"/>

                </RelativeLayout>

                <TextView
                    android:id="@+id/usuarioNombreChat"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text= "Otro usuario"
                    android:gravity="bottom"
                    android:textSize="20sp"
                    android:fontFamily="@font/segoe_ui_bold"
                    android:textColor="?attr/textos"
                    android:textAlignment="textStart"
                    android:layout_marginStart="40dp"/>

            </RelativeLayout>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerMessages"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/colorBackgroundChat"
            app:cardCornerRadius="20dp"
            android:layout_margin="3dp">

            <EditText
                android:id="@+id/messageInput"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="Mensaje"
                android:fontFamily="@font/segoe_ui_regular"
                android:backgroundTint="@android:color/transparent"
                android:paddingLeft="15dp"/>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/sendBtn"
        android:layout_width="45dp"
        android:layout_height="45dp"
        app:cardBackgroundColor="?attr/fondoBotones"
        app:cardCornerRadius="100dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginBottom="3dp"
        android:layout_marginRight="3dp">

        <ImageView
            android:src="@drawable/enviarmensaje_icon"
            android:tint="?attr/textoBotones"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="7dp"/>

    </androidx.cardview.widget.CardView>

</RelativeLayout>


