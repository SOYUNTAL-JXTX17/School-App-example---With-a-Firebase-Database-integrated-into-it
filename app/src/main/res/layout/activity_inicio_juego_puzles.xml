<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingHorizontal="32dp"
    android:paddingVertical="32dp"
    tools:context=".juegosApartado.juegos.resolverPuzzles.InicioJuegoPuzlesActivity">


    <LinearLayout
        android:id="@+id/backButton"
        android:layout_width="wrap_content"
        android:layout_height="41dp"
        android:gravity="center_vertical"
        android:layout_alignParentTop="true"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:tint="?attr/backButton"
            android:contentDescription="volver"
            android:src="@drawable/arrow_back" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutTituloJuegoPuzles"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_alignParentTop="true"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Puzles"
            android:textAllCaps="true"
            android:textStyle="bold"
            android:fontFamily="@font/segoe_ui_bold"
            android:textColor="?attr/textos"
            android:textSize="30sp"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutDificultad"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_below="@+id/layoutTituloJuegoPuzles"
        android:layout_alignParentBottom="true">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selecciona la dificultad"
            android:textAllCaps="true"
            android:fontFamily="@font/segoe_ui_bold"
            android:textStyle="bold"
            android:textColor="?attr/textos"
            android:textSize="20sp"
            android:textAlignment="center"/>

        <GridLayout
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:columnCount="1"
            android:rowCount="3">

            <androidx.cardview.widget.CardView
                android:id="@+id/botonFacil"
                app:cardBackgroundColor="@color/LimeGreen"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                app:cardCornerRadius="16dp"
                app:cardUseCompatPadding="true"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_column="0"
                android:layout_row="0">

                <TextView
                    android:layout_gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAlignment="center"
                    android:text="Facil"
                    android:fontFamily="@font/seg_ui_semibold"
                    android:textAllCaps="true"
                    android:textSize="20sp"
                    android:textColor="@color/black"
                    android:textStyle="bold"/>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/botonNormal"
                app:cardBackgroundColor="@color/yellow"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                app:cardCornerRadius="16dp"
                app:cardUseCompatPadding="true"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_column="0"
                android:layout_row="1">

                <TextView
                    android:layout_gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAlignment="center"
                    android:text="Normal"
                    android:fontFamily="@font/seg_ui_semibold"
                    android:textAllCaps="true"
                    android:textSize="20sp"
                    android:textColor="@color/black"
                    android:textStyle="bold"/>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/botonDificil"
                app:cardBackgroundColor="@color/red"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                app:cardCornerRadius="16dp"
                app:cardUseCompatPadding="true"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_column="0"
                android:layout_row="2">

                <TextView
                    android:layout_gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAlignment="center"
                    android:text="Dificil"
                    android:textAllCaps="true"
                    android:fontFamily="@font/seg_ui_semibold"
                    android:textSize="20sp"
                    android:textColor="@color/black"
                    android:textStyle="bold"/>

            </androidx.cardview.widget.CardView>
        </GridLayout>

    </LinearLayout>
</RelativeLayout>
