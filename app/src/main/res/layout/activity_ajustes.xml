<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".ajustesApartado.AjustesActivity">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:orientation="horizontal">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:background="@drawable/inicio_bienvenida_background"
            android:layout_marginBottom="20dp"
            android:paddingHorizontal="32dp"
            android:paddingBottom="20dp">

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="bottom">

                <ImageView
                    android:id="@+id/backButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/arrow_back"
                    android:tint="?attr/textos"/>

            </RelativeLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text= "Ajustes"
                android:gravity="bottom"
                android:textAllCaps="true"
                android:textSize="20sp"
                android:fontFamily="@font/segoe_ui_bold"
                android:textColor="?attr/textos"
                android:textAlignment="center"/>

        </RelativeLayout>
    </LinearLayout>

    <ScrollView
        android:id="@+id/layoutAjustes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/swModoOscuro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false"
                android:text="Modo oscuro   "
                android:textColor="?attr/textos"
                android:fontFamily="@font/seg_ui_semibold"
                android:layout_marginLeft="32dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:textSize="20sp"/>

            <LinearLayout
                android:id="@+id/cerrarSesionButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginLeft="28dp">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/icon_back_white"
                    android:tint="?attr/textos" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cerrar sesion"
                    android:textAlignment="textStart"
                    android:textSize="20sp"
                    android:textColor="?attr/textos"
                    android:fontFamily="@font/seg_ui_semibold" />
            </LinearLayout>

        </LinearLayout>

    </ScrollView>
</LinearLayout>