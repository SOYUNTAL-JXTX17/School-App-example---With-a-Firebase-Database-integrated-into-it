<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingVertical="32dp"
    android:paddingHorizontal="32dp"
    tools:context=".juegosApartado.juegos.memorizarColores.JuegoMemoria">

    <RelativeLayout
        android:id="@+id/layoutTituloJuegoMemoria"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <LinearLayout
            android:id="@+id/backButton"
            android:layout_width="wrap_content"
            android:layout_height="41dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:tint="?attr/backButton"
                android:src="@drawable/arrow_back" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Memoriza los colores"
                android:textAlignment="center"
                android:textAllCaps="true"
                android:fontFamily="@font/segoe_ui_bold"
                android:textColor="?attr/textos"
                android:textSize="30sp"/>

        </LinearLayout>
    </RelativeLayout>

    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/filaInfoJuego"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/layoutTituloJuegoMemoria"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="30dp"
        android:gravity="start">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="start">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RECORD: "
                android:textStyle="bold"
                android:fontFamily="@font/seg_ui_semibold"
                android:textColor="?attr/textos"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/record"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textStyle="bold"
                android:fontFamily="@font/seg_ui_semibold"
                android:textColor="?attr/textos"
                android:textSize="15sp"/>

        </androidx.appcompat.widget.LinearLayoutCompat>

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <TextView
                android:id="@+id/clickstexto"
                android:visibility="invisible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Clicks: "
                android:fontFamily="@font/seg_ui_semibold"
                android:textColor="?attr/textos"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/clicks"
                android:visibility="invisible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:fontFamily="@font/seg_ui_semibold"
                android:textColor="?attr/textos"
                android:textSize="15sp"/>

        </androidx.appcompat.widget.LinearLayoutCompat>

    </androidx.appcompat.widget.LinearLayoutCompat>

    <androidx.cardview.widget.CardView
        android:id="@+id/pantallaborde"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        app:cardBackgroundColor="@color/black"
        app:cardCornerRadius="16dp"
        app:layout_constraintTop_toBottomOf="@id/filaInfoJuego"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.cardview.widget.CardView
        android:id="@+id/pantalla"
        android:layout_width="match_parent"
        android:layout_height="190dp"
        app:cardBackgroundColor="@color/LightGrey"
        app:cardCornerRadius="16dp"
        app:layout_constraintTop_toBottomOf="@id/filaInfoJuego"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="4dp"
        android:layout_marginTop="5dp"
        android:layout_marginEnd="4dp">

        <TextView
            android:id="@+id/textoPantalla"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="55sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_gravity="center"/>
    </androidx.cardview.widget.CardView>


    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/filaColores1"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:layout_marginTop="60dp"
        android:gravity="center_horizontal"
        app:layout_constraintTop_toBottomOf="@+id/pantalla">

        <androidx.cardview.widget.CardView
            android:id="@+id/red"
            android:layout_width="50dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="4dp"
            app:cardCornerRadius="30dp"
            app:cardBackgroundColor="@color/red"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/blue"
            android:layout_width="50dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="4dp"
            app:cardCornerRadius="30dp"
            app:cardBackgroundColor="@color/blue"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/yellow"
            android:layout_width="50dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="4dp"
            app:cardCornerRadius="30dp"
            app:cardBackgroundColor="@color/yellow"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/purple"
            android:layout_width="50dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="4dp"
            app:cardCornerRadius="30dp"
            app:cardBackgroundColor="@color/purple"/>

    </androidx.appcompat.widget.LinearLayoutCompat>

    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/filaColores2"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:gravity="center_horizontal"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@+id/filaColores1">

        <androidx.cardview.widget.CardView
            android:id="@+id/Orange"
            android:layout_width="50dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="4dp"
            app:cardCornerRadius="30dp"
            app:cardBackgroundColor="@color/Orange"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/Pink"
            android:layout_width="50dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="4dp"
            app:cardCornerRadius="30dp"
            app:cardBackgroundColor="@color/Pink"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/Brown"
            android:layout_width="50dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="4dp"
            app:cardCornerRadius="30dp"
            app:cardBackgroundColor="@color/Brown"/>

    </androidx.appcompat.widget.LinearLayoutCompat>


    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/comenzarPartida"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:background="?attr/fondoBotones"
        app:layout_constraintTop_toBottomOf="@id/filaColores2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="60dp"
        android:text="Comenzar partida"
        android:textAlignment="center"
        android:textColor="?attr/textoBotones"
        android:fontFamily="@font/seg_ui_semibold"
        android:textSize="20sp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMensajes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/comenzarPartida"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>